{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListPactoAssetPrefixes",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::pacto-prod-assets-829279763575",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "campaigns/*",
            "users/*",
            "profiles/*"
          ]
        }
      }
    },
    {
      "Sid": "ManagePactoAssetObjects",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::pacto-prod-assets-829279763575/campaigns/*",
        "arn:aws:s3:::pacto-prod-assets-829279763575/users/*",
        "arn:aws:s3:::pacto-prod-assets-829279763575/profiles/*"
      ]
    }
  ]
}
